{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.apb.cursor.request.v1",
  "title": "apb.cursor request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "apb.cursor"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {
        "direction": {
          "type": "string",
          "enum": [
            "write",
            "read",
            "all"
          ],
          "description": "args.direction 的 action-specific 参数值。",
          "x-description-zh": "args.direction 的 action-specific 参数值。"
        },
        "name": {
          "type": "string",
          "description": "已保存配置、游标、列表或接口配置名称。",
          "x-description-zh": "已保存配置、游标、列表或接口配置名称。"
        },
        "op": {
          "type": "string",
          "enum": [
            "begin",
            "next",
            "prev",
            "pre",
            "last"
          ],
          "description": "游标移动或协议浏览操作。",
          "x-description-zh": "游标移动或协议浏览操作。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ],
          "description": "仅解释不带单位的时间数字；带单位时间字符串优先，auto 不改变带单位值。",
          "x-description-zh": "仅解释不带单位的时间数字；带单位时间字符串优先，auto 不改变带单位值。"
        }
      },
      "additionalProperties": false,
      "required": [
        "name",
        "op"
      ]
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Move a cursor across APB transfers.",
  "x-purpose": "在 APB transfer 间移动游标。",
  "x-how_it_works": "基于 APB 查询结果按 op/direction 定位 begin/next/prev 等。",
  "x-when_to_use": "交互式浏览 APB 事务。",
  "x-arg_contract_notes": "required: name, op",
  "x-description-zh": "在 APB transfer 间移动游标。",
  "x-agent": {
    "use_when": [
      "需要执行该 action 的 catalog 所述能力。"
    ],
    "do_not_use_when": [
      "任务不属于该 action 的公开合同。"
    ],
    "alternatives": [],
    "constraints": [
      "required: name, op"
    ]
  }
}
