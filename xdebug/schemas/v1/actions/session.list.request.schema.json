{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.session.list.request.v1",
  "title": "session.list request",
  "type": "object",
  "required": [
    "api_version",
    "action"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "session.list"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {},
      "additionalProperties": false,
      "required": []
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "List active debug sessions.",
  "x-purpose": "列出当前 session。",
  "x-how_it_works": "读取 SessionManager 中的活动 session 元数据。",
  "x-when_to_use": "确认已有 session_id 和资源类型。",
  "x-arg_contract_notes": "none",
  "x-description-zh": "列出当前 session。",
  "x-agent": {
    "use_when": [
      "列出当前 session。"
    ],
    "do_not_use_when": [
      "不要把本 action 用于 session.close、session.doctor 的业务目标；请改用列出的同域 action。"
    ],
    "alternatives": [
      {
        "action": "session.close",
        "when": "关闭指定 session。"
      },
      {
        "action": "session.doctor",
        "when": "诊断当前 session。"
      }
    ],
    "constraints": [
      "none"
    ]
  }
}
