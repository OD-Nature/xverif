{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.actions.response.v1",
  "title": "actions response",
  "type": "object",
  "required": [
    "api_version",
    "ok",
    "action",
    "summary",
    "data"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "action": {
      "type": "string",
      "enum": [
        "actions"
      ]
    },
    "summary": {
      "type": "object",
      "required": ["action_count", "removed_count", "verbose"],
      "properties": {
        "action_count": {"type": "integer", "minimum": 0},
        "removed_count": {"type": "integer", "minimum": 0},
        "verbose": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "data": {
      "type": "object",
      "required": ["actions", "removed", "modes"],
      "properties": {
        "actions": {
          "type": "array",
          "items": {
            "oneOf": [
              {"type": "string"},
              {"type": "object", "required": ["name", "category", "status", "requires"]}
            ]
          }
        },
        "removed": {"type": "array", "items": {"type": "string"}},
        "modes": {"type": "object"}
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "array"
    },
    "warnings": {
      "type": "array"
    },
    "error": {},
    "meta": {
      "type": "object"
    }
  },
  "additionalProperties": true,
  "description": "actions response: 列出当前运行时公开 action catalog。",
  "x-output_notes": "返回该 action 的 summary/data/error/meta；具体字段以 response schema 和 response example 为准。"
}
