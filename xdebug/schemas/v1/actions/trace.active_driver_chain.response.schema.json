{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.trace.active_driver_chain.response.v1",
  "title": "trace.active_driver_chain response",
  "type": "object",
  "required": [
    "api_version",
    "ok",
    "action",
    "summary",
    "data"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "action": {
      "type": "string",
      "enum": [
        "trace.active_driver_chain"
      ]
    },
    "tool": {
      "type": "object"
    },
    "session": {
      "type": [
        "object",
        "null"
      ]
    },
    "summary": {
      "type": "object",
      "required": [
        "signal",
        "time",
        "hop_count",
        "termination",
        "truncated"
      ],
      "properties": {
        "signal": {
          "type": "string"
        },
        "time": {
          "type": "string"
        },
        "hop_count": {
          "type": "integer",
          "minimum": 0
        },
        "termination": {
          "type": "string"
        },
        "termination_detail": {
          "type": "string"
        },
        "truncated": {
          "type": "boolean"
        },
        "limit_hint": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "data": {
      "type": "object",
      "required": [
        "hops"
      ],
      "properties": {
        "summary": {
          "type": "object"
        },
        "requested_time": {
          "type": "string"
        },
        "time_semantics": {
          "type": "object"
        },
        "evidence_scope": {
          "type": "string"
        },
        "evidence_status": {
          "type": "string"
        },
        "evidence_source": {
          "type": [
            "string",
            "null"
          ]
        },
        "static_candidate_count": {
          "type": "integer",
          "minimum": 0
        },
        "active_check_count": {
          "type": "integer",
          "minimum": 0
        },
        "hops": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/hop"
          }
        },
        "ambiguity_evidence": {
          "$ref": "#/$defs/ambiguity_evidence"
        },
        "truncated": {
          "type": "boolean"
        },
        "common_blocks": {
          "type": "array"
        }
      },
      "additionalProperties": false
    },
    "error": {},
    "meta": {
      "type": "object"
    }
  },
  "$defs": {
    "sample_value": {
      "type": "object",
      "required": [
        "status",
        "value",
        "known",
        "value_time"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ok", "signal_not_found", "missing_value"]
        },
        "value": {
          "type": ["string", "null"]
        },
        "known": {
          "type": ["boolean", "null"]
        },
        "value_time": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    },
    "rhs_sample": {
      "type": "object",
      "required": ["signal", "before", "after", "changed"],
      "properties": {
        "signal": {"type": "string"},
        "before": {"$ref": "#/$defs/sample_value"},
        "after": {"$ref": "#/$defs/sample_value"},
        "changed": {"type": ["boolean", "null"]}
      },
      "additionalProperties": false
    },
    "ambiguity_statement": {
      "type": "object",
      "required": [
        "kind",
        "driver",
        "file",
        "line",
        "rhs_signal_count",
        "returned_rhs_signal_count",
        "complete",
        "rhs_samples"
      ],
      "properties": {
        "kind": {"type": "string"},
        "driver": {"type": "string"},
        "file": {"type": "string"},
        "line": {"type": "integer", "minimum": 0},
        "rhs_signal_count": {"type": "integer", "minimum": 0},
        "returned_rhs_signal_count": {"type": "integer", "minimum": 0},
        "complete": {"type": "boolean"},
        "rhs_samples": {
          "type": "array",
          "items": {"$ref": "#/$defs/rhs_sample"}
        }
      },
      "additionalProperties": false
    },
    "ambiguity_evidence": {
      "type": "object",
      "required": [
        "kind",
        "signal",
        "active_time",
        "hop_index",
        "statement_count",
        "rhs_signal_count",
        "returned_rhs_signal_count",
        "omitted_rhs_signal_count",
        "complete",
        "truncation_scope",
        "statements"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["multiple_active_candidates", "multiple_rhs_sources"]
        },
        "signal": {"type": "string"},
        "active_time": {"type": "string"},
        "hop_index": {"type": "integer", "minimum": 0},
        "statement_count": {"type": "integer", "minimum": 1},
        "rhs_signal_count": {"type": "integer", "minimum": 0},
        "returned_rhs_signal_count": {"type": "integer", "minimum": 0},
        "omitted_rhs_signal_count": {"type": "integer", "minimum": 0},
        "complete": {"type": "boolean"},
        "truncation_scope": {
          "type": ["string", "null"],
          "enum": ["ambiguity_rhs_samples", null]
        },
        "statements": {
          "type": "array",
          "items": {"$ref": "#/$defs/ambiguity_statement"}
        }
      },
      "additionalProperties": false
    },
    "hop": {
      "allOf": [
        {
          "$ref": "#/$defs/source_path"
        },
        {
          "type": "object",
          "required": [
            "index"
          ],
          "properties": {
            "index": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      ]
    },
    "source_path": {
      "type": "object",
      "required": [
        "file",
        "line",
        "source_context",
        "signal_path"
      ],
      "properties": {
        "file": {
          "type": "string"
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "source_context": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "line",
              "text",
              "active"
            ],
            "properties": {
              "line": {
                "type": "integer",
                "minimum": 1
              },
              "text": {
                "type": "string"
              },
              "active": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          }
        },
        "signal_path": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "additionalProperties": true,
  "description": "Trace an active-driver chain across multiple levels.",
  "x-output_notes": "返回该 action 的 summary/data/error/meta；具体字段以 response schema 和 response example 为准。",
  "x-description-zh": "展开 active driver 链。"
}
