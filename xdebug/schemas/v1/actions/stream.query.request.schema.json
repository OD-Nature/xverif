{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.stream.query.request.v1",
  "title": "stream.query request",
  "type": "object",
  "required": [
    "api_version",
    "action",
    "args"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "action": {
      "type": "string",
      "enum": [
        "stream.query"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "required": [
        "stream",
        "query"
      ],
      "properties": {
        "channel": {
          "type": "string"
        },
        "filter": {
          "type": "object",
          "required": [
            "fields"
          ],
          "properties": {
            "position": {
              "type": "string",
              "enum": [
                "sop",
                "eop"
              ]
            },
            "fields": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": {
                "oneOf": [
                  {
                    "type": "object",
                    "required": [
                      "mode",
                      "values"
                    ],
                    "properties": {
                      "mode": {
                        "const": "exact"
                      },
                      "values": {
                        "type": "array",
                        "minItems": 1,
                        "uniqueItems": true,
                        "items": {
                          "type": "string",
                          "minLength": 1,
                          "description": "Known unsigned integer or SystemVerilog literal of arbitrary width; X/Z and 0x are rejected.",
                          "x-description-zh": "任意位宽的已知无符号整数或 SystemVerilog literal；不允许 X/Z 和 0x。"
                        }
                      }
                    },
                    "additionalProperties": false
                  },
                  {
                    "type": "object",
                    "required": [
                      "mode",
                      "begin",
                      "end"
                    ],
                    "properties": {
                      "mode": {
                        "const": "range"
                      },
                      "begin": {
                        "type": "string",
                        "minLength": 1,
                        "description": "Known unsigned integer or SystemVerilog literal of arbitrary width; X/Z and 0x are rejected.",
                        "x-description-zh": "任意位宽的已知无符号整数或 SystemVerilog literal；不允许 X/Z 和 0x。"
                      },
                      "end": {
                        "type": "string",
                        "minLength": 1,
                        "description": "Known unsigned integer or SystemVerilog literal of arbitrary width; X/Z and 0x are rejected.",
                        "x-description-zh": "任意位宽的已知无符号整数或 SystemVerilog literal；不允许 X/Z 和 0x。"
                      }
                    },
                    "additionalProperties": false
                  },
                  {
                    "type": "object",
                    "required": [
                      "mode",
                      "value",
                      "mask"
                    ],
                    "properties": {
                      "mode": {
                        "const": "mask"
                      },
                      "value": {
                        "type": "string",
                        "minLength": 1,
                        "description": "Known unsigned integer or SystemVerilog literal of arbitrary width; X/Z and 0x are rejected.",
                        "x-description-zh": "任意位宽的已知无符号整数或 SystemVerilog literal；不允许 X/Z 和 0x。"
                      },
                      "mask": {
                        "type": "string",
                        "minLength": 1,
                        "description": "Known unsigned integer or SystemVerilog literal of arbitrary width; X/Z and 0x are rejected.",
                        "x-description-zh": "任意位宽的已知无符号整数或 SystemVerilog literal；不允许 X/Z 和 0x。"
                      }
                    },
                    "additionalProperties": false
                  }
                ]
              }
            }
          },
          "additionalProperties": false,
          "description": "AND-combined Stream field filters; each field selects exact queue, inclusive range, or value/mask.",
          "x-description-zh": "Stream 字段间取 AND；每个字段只能选择精确值队列、闭区间或 value/mask。packet stream 必须指定 SOP/EOP position。"
        },
        "line_limit": {
          "type": "integer",
          "minimum": 1,
          "description": "控制 response/xout 中 item、finding、event、transaction 或 row 的最大返回行数。"
        },
        "packet_index": {
          "type": "integer",
          "minimum": 0
        },
        "query": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "object"
            }
          ],
          "description": "stream 查询条件。"
        },
        "stream": {
          "type": "string",
          "description": "已保存 stream 配置名称。"
        },
        "time_range": {
          "type": "object",
          "properties": {
            "begin": {
              "type": "string"
            },
            "end": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "description": "查询或分析的时间窗口。"
        },
        "time_unit": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "ps",
            "ns",
            "us",
            "ms",
            "s"
          ]
        }
      },
      "additionalProperties": false
    },
    "limits": {
      "type": "object"
    },
    "request_id": {
      "type": "string"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Query and filter stream transfers, stalls, and packets.",
  "x-purpose": "查询并过滤 stream transfer/packet。",
  "x-how_it_works": "无 sop/eop 时按 transfer 在线过滤；packet stream 必须用 filter.position=sop/eop 选择边界拍并返回整包。",
  "x-when_to_use": "按多个 data/beat/stable 字段筛选流事务。",
  "x-arg_contract_notes": "required: stream, query; filter.fields conditions AND; each mode exact/range/mask; packet filter requires position sop/eop",
  "x-description-zh": "查询并按多个字段过滤 stream transfer 或 packet。"
}
