{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xdebug.session.doctor.request.v1",
  "title": "session.doctor request",
  "type": "object",
  "required": [
    "api_version",
    "action"
  ],
  "properties": {
    "api_version": {
      "type": "string",
      "enum": [
        "xdebug.v1"
      ]
    },
    "request_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "session.doctor"
      ]
    },
    "target": {
      "type": "object"
    },
    "args": {
      "type": "object",
      "properties": {},
      "additionalProperties": false,
      "required": []
    },
    "limits": {
      "type": "object"
    },
    "auth_token": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Diagnose debug-session resources and accessibility.",
  "x-purpose": "诊断当前 session。",
  "x-how_it_works": "检查 session 资源、路径和可访问状态。",
  "x-when_to_use": "定位 daidir/fsdb/session 绑定问题。",
  "x-arg_contract_notes": "none",
  "x-description-zh": "诊断当前 session。",
  "x-agent": {
    "use_when": [
      "诊断当前 session。"
    ],
    "do_not_use_when": [
      "不要把本 action 用于 session.close、session.gc 的业务目标；请改用列出的同域 action。"
    ],
    "alternatives": [
      {
        "action": "session.close",
        "when": "关闭指定 session。"
      },
      {
        "action": "session.gc",
        "when": "清理过期 session。"
      }
    ],
    "constraints": [
      "none"
    ]
  }
}
