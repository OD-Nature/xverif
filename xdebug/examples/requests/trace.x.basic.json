{
  "api_version": "xdebug.v1",
  "action": "trace.x",
  "target": {"session_id": "xprop_debug"},
  "args": {
    "signal": "trace_x_xprop_tb.observed",
    "time": "18ns",
    "value_format": "hex"
  },
  "limits": {
    "max_depth": 8,
    "max_nodes": 256,
    "max_time_steps": 128,
    "max_trace_signals": 128,
    "max_chains": 8
  }
}
